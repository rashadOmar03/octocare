# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT Secret (generate a random 64-char string)
SECRET_KEY=change-me-to-a-random-64-character-string

# ─── AI Chat: Groq API (free tier — Llama 3.3 70B) ──────────────────────────
LM_STUDIO_URL=https://api.groq.com/openai/v1
LM_STUDIO_MODEL=llama-3.3-70b-versatile
LM_API_KEY=gsk_your_groq_api_key_here

# ─── Voice Input: Groq Whisper (uses same Groq API key) ─────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3
# Production uses Groq only. For offline local STT: pip install -r requirements-dev.txt

# ─── Email (OTP codes) — Brevo recommended on Railway ───────────────────────
# Gmail SMTP often fails from Railway (blocked or marked spam). Use Brevo instead:
# 1. Sign up free at https://www.brevo.com
# 2. Senders → verify clinova.clinic@gmail.com
# 3. SMTP & API → create API key
# 4. Set BREVO_API_KEY below in Railway Variables
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=clinova.clinic@gmail.com

# Fallback: Gmail SMTP (works locally, unreliable on Railway)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=clinova.clinic@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_TLS=true

# Optional alternative: Resend (https://resend.com)
# RESEND_API_KEY=re_your_resend_api_key

# CORS - set to your frontend domain(s)
CORS_ORIGINS=*
