# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT Secret (generate a random 64-char string)
SECRET_KEY=change-me-to-a-random-64-character-string

# ─── Option A: YOUR model on RunPod GPU (Ollama / vLLM) ─────────────────────
# OpenAI-compatible endpoint from your GPU pod (NOT Groq/Gemini)
LM_STUDIO_URL=https://YOUR-RUNPOD-POD-ID-11434.proxy.runpod.net/v1
LM_STUDIO_MODEL=gemma-4-E2B-it-Q4_K_M
LM_API_KEY=ollama

# Whisper on same GPU pod (Step 8 — we wire this together)
# Railway has no GPU; voice runs on RunPod, backend calls this URL
WHISPER_API_URL=https://YOUR-RUNPOD-POD-ID-8001.proxy.runpod.net/transcribe

# ─── Fallback: cloud APIs (only if you skip self-hosted GPU) ─────────────────
# LM_STUDIO_URL=https://api.groq.com/openai/v1
# LM_STUDIO_MODEL=llama-3.3-70b-versatile
# LM_API_KEY=gsk_your_groq_api_key_here

# SMTP for email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=clinova.clinic@gmail.com
SMTP_PASS=your_app_password

# CORS - set to your frontend domain(s)
CORS_ORIGINS=*
