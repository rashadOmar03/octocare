# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT Secret (generate a random 64-char string)
SECRET_KEY=change-me-to-a-random-64-character-string

# ─── AI Chat: Groq API (free tier — Llama 3.3 70B) ──────────────────────────
LM_STUDIO_URL=https://api.groq.com/openai/v1
LM_STUDIO_MODEL=llama-3.3-70b-versatile
LM_API_KEY=gsk_your_groq_api_key_here

# ─── Voice Input: Groq Whisper (uses same Groq API key) ─────────────────────
# If set, Groq Whisper is used instead of local faster-whisper (no GPU needed)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# ─── SMTP for email notifications (exact names the backend reads) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=clinova.clinic@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_TLS=true

# CORS - set to your frontend domain(s)
CORS_ORIGINS=*
